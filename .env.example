# ── Zorunlu ──────────────────────────────────────────────────────────────────
# Gemini API anahtarı — YALNIZCA sunucuda kullanılır, client'a asla gönderilmez.
# Anahtarı https://aistudio.google.com/app/apikey adresinden alabilirsiniz.
GEMINI_API_KEY=your_gemini_api_key_here

# Uygulama URL'si (production'da https://vizeakil.com olacak)
APP_URL=http://localhost:3000

# ── Opsiyonel ────────────────────────────────────────────────────────────────
# Express sunucu portu (default: 3001)
PORT=3001

# JWT secret — premium doğrulama için (en az 32 karakter rastgele string)
JWT_SECRET=change_this_to_a_long_random_string_in_production
