# ── Zorunlu ──────────────────────────────────────────────────────────────────
# Anthropic (Claude) API anahtarı — YALNIZCA sunucuda kullanılır, client'a asla gönderilmez.
# Anahtarı https://console.anthropic.com/settings/keys adresinden alabilirsiniz.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Uygulama URL'si (production'da https://vizeakil.com olacak)
APP_URL=http://localhost:3000

# ── Opsiyonel ────────────────────────────────────────────────────────────────
# Express sunucu portu (default: 3001)
PORT=3001

# JWT secret — premium doğrulama için (en az 32 karakter rastgele string)
JWT_SECRET=change_this_to_a_long_random_string_in_production

# ── Randevu Takip E-posta (SMTP) ─────────────────────────────────────────
# Gmail kullanmak için: Google Hesabı → Güvenlik → 2FA etkinleştir → Uygulama Şifresi oluştur
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=sizin@gmail.com
# SMTP_PASS=xxxx_xxxx_xxxx_xxxx  ← Gmail Uygulama Şifresi (boşluksuz)

# Alternatif: Brevo (Sendinblue), Mailjet, vb. SMTP relay hizmetleri de kullanılabilir.
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=api_key_here
# SMTP_PASS=api_secret_here

# Manuel kontrol tetiklemek için gizli anahtar (opsiyonel)
# CHECK_SECRET=gizli_anahtar_buraya
